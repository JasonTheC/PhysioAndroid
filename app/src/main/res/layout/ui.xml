<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:context=".MainActivity">

    <!--
        The FrameLayout fills the screen. The visible overlay container is the
        inner LinearLayout (`@id/rl_content`) which is sized to its content and
        positioned with `android:layout_gravity="bottom|start"` so it appears
        in the bottom-left corner.
    -->

    <LinearLayout
        android:id="@+id/rl_content"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#000000ff"
        android:padding="0dp"
        android:layout_margin="0dp"
        android:gravity="center_horizontal"
        >

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/Closebutton"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_marginTop="4dp"
                android:onClick="closeApp"
                android:text="X"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:background="#000000ff"
                android:gravity="start"/>

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transverse"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:layout_marginTop="4dp"/>

           

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/toggleButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="#FF00FF00"
                android:onClick="toggleFan"
                android:gravity="center"
                android:textAlignment="center"
                android:text="Start"
                android:textSize="10sp" />

            


    </LinearLayout>

</FrameLayout>
