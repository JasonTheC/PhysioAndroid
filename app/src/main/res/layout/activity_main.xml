<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.PhysioAndroid.MainActivity"
    android:background="@drawable/human">

    <!-- ============ TOP: Title + inputs ============ -->

    <TextView
        android:id="@+id/textView2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Please select which body part you'd like to image"
        android:textSize="15sp"
        android:textColor="@android:color/black"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/editPatientName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="4dp"
        android:hint="Patient Name"
        android:inputType="textPersonName"
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        android:background="@android:drawable/edit_text"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/textView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/editStudyNotes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="4dp"
        android:hint="Study Notes"
        android:textColorHint="@color/black"
        android:textColor="@color/black"
        android:inputType="textMultiLine"
        android:minLines="1"
        android:maxLines="3"
        android:background="@android:drawable/edit_text"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/editPatientName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ============ MIDDLE: Body part buttons (positioned on diagram) ============ -->

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/shoulderButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="#CC666666"
        android:text="@string/Shoulder"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="164dp"
        android:layout_marginEnd="128dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/abdoButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="#CC666666"
        android:text="@string/Abdomen"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="296dp"
        android:layout_marginEnd="168dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/quadButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="#CC666666"
        android:text="Quad"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="124dp"
        android:layout_marginBottom="24dp" />

    <!-- ============ BOTTOM: Controls panel ============ -->

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EE111111"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: Probe toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Probe:"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <ToggleButton
                android:id="@+id/toggleProbe"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:textOff="UProbe"
                android:textOn="Butterfly"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Row 2: IMU type (full width so labels aren't clipped) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IMU:"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/imuSpinner"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:popupBackground="@android:color/white" />
        </LinearLayout>

        <!-- Row 2: BLE name input with clear label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BLE Device Name (for IMU matching):"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editImuBleName"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="e.g. WT901BLE, CUS_IMU"
            android:textColorHint="#777777"
            android:textColor="#000000"
            android:textSize="14sp"
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:maxLines="1"
            android:singleLine="true"
            android:layout_marginBottom="10dp" />

        <!-- Row 3: Scan for nearby BLE devices -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Or pick from nearby devices:"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <Spinner
                android:id="@+id/imuDeviceSpinner"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:popupBackground="@android:color/white" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/scanImuDevicesButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="#CC4466EE"
                android:text="Scan"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </LinearLayout>

        <!-- Row 4: Close app -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/CloseApp"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#CC990000"
            android:onClick="closeApp"
            android:text="@string/close_app"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>